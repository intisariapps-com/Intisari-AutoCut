# Auto convert LF untuk shell scripts (penting untuk Linux/Termux)
*.sh text eol=lf
*.bash text eol=lf

# Auto convert CRLF untuk Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.deb binary
*.apk binary
*.png binary
*.jpg binary
*.gif binary
*.zip binary
